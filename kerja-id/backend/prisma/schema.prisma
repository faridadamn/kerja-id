// KERJA.ID — Database Schema
// Generated for Sprint 1: Auth & Profile Foundation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH & USER
// ============================================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String?
  phone         String?   @unique
  provider      AuthProvider @default(LOCAL)
  providerId    String?
  role          UserRole  @default(JOB_SEEKER)
  emailVerified Boolean   @default(false)
  verifyToken   String?
  resetToken    String?
  resetTokenExp DateTime?
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  profile       Profile?
  experiences   Experience[]
  educations    Education[]
  skills        UserSkill[]
  certifications Certification[]
  portfolioItems PortfolioItem[]
  cvVersions    CvVersion[]
  applications  Application[]
  savedJobs     SavedJob[]
  moodEntries   MoodEntry[]

  @@index([email])
  @@index([phone])
  @@index([provider, providerId])
  @@map("users")
}

enum AuthProvider {
  LOCAL
  GOOGLE
  APPLE
}

enum UserRole {
  JOB_SEEKER
  EMPLOYER
  MENTOR
  ADMIN
  SUPER_ADMIN
}

// ============================================================
// PROFILE
// ============================================================

model Profile {
  id              String    @id @default(uuid())
  userId          String    @unique
  fullName        String
  headline        String?
  bio             String?
  photoUrl        String?
  location        String?
  city            String?
  province        String?
  website         String?
  linkedinUrl     String?
  githubUrl       String?
  portfolioUrl    String?
  expectedSalary  Int?
  jobType         String[]   // full-time, part-time, contract, freelance, internship
  preferredLocations String[]
  remotePreference String?  // remote, hybrid, onsite, any
  profileCompletion Int      @default(0)
  isPublic        Boolean   @default(true)
  showEmail       Boolean   @default(false)
  showPhone       Boolean   @default(false)
  showSalary      Boolean   @default(false)
  username        String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([username])
  @@map("profiles")
}

// ============================================================
// EXPERIENCE & EDUCATION
// ============================================================

model Experience {
  id          String    @id @default(uuid())
  userId      String
  company     String
  position    String
  description String?
  startDate   DateTime
  endDate     DateTime?
  isCurrent   Boolean   @default(false)
  location    String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("experiences")
}

model Education {
  id          String    @id @default(uuid())
  userId      String
  institution String
  degree      String    // SMA, D3, S1, S2, S3
  field       String
  startYear   Int
  endYear     Int?
  gpa         Float?
  description String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("educations")
}

// ============================================================
// SKILLS
// ============================================================

model UserSkill {
  id         String    @id @default(uuid())
  userId     String
  name       String
  level      Int       @default(1) // 1-5
  verified   Boolean   @default(false)
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@map("user_skills")
}

model SkillDefinition {
  id          String    @id @default(uuid())
  name        String    @unique
  categoryId  String?
  aliases     String[]
  description String?
  demandScore Float     @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  category SkillCategory? @relation(fields: [categoryId], references: [id])

  @@index([name])
  @@index([categoryId])
  @@map("skill_definitions")
}

model SkillCategory {
  id        String           @id @default(uuid())
  name      String           @unique
  industry  String?
  skills    SkillDefinition[]
  createdAt DateTime         @default(now())

  @@map("skill_categories")
}

// ============================================================
// CERTIFICATIONS & PORTFOLIO
// ============================================================

model Certification {
  id          String    @id @default(uuid())
  userId      String
  name        String
  issuer      String
  date        DateTime?
  url         String?
  imageUrl    String?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("certifications")
}

model PortfolioItem {
  id          String    @id @default(uuid())
  userId      String
  title       String
  description String?
  url         String?
  images      String[]
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("portfolio_items")
}

// ============================================================
// JOBS & COMPANIES (Prepared for Sprint 3)
// ============================================================

model Company {
  id          String    @id @default(uuid())
  name        String
  logoUrl     String?
  industry    String?
  size        String?   // 1-10, 11-50, 51-200, 201-500, 501-1000, 1000+
  website     String?
  description String?
  location    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  jobs Job[]

  @@index([name])
  @@map("companies")
}

model Job {
  id          String    @id @default(uuid())
  title       String
  companyId   String?
  company     Company?  @relation(fields: [companyId], references: [id])
  location    String?
  city        String?
  province    String?
  salaryMin   Int?
  salaryMax   Int?
  salaryLabel String?   // "Rp 5-8 juta", "Negotiable"
  type        JobType   @default(FULL_TIME)
  level       JobLevel  @default(ENTRY)
  description String
  requirements String?
  skills      String[]
  source      String    // linkedin, jobstreet, glints, etc
  sourceUrl   String?
  sourceId    String?
  postedAt    DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  applications Application[]
  savedBy      SavedJob[]

  @@index([companyId])
  @@index([location])
  @@index([type])
  @@index([level])
  @@index([isActive, postedAt])
  @@index([source, sourceId])
  @@map("jobs")
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCE
  INTERNSHIP
}

enum JobLevel {
  ENTRY
  JUNIOR
  MID
  SENIOR
  MANAGER
  DIRECTOR
}

// ============================================================
// APPLICATIONS & JOBTRACKER (Prepared for Sprint 5)
// ============================================================

model Application {
  id              String            @id @default(uuid())
  userId          String
  jobId           String?
  cvVersionId     String?
  position        String
  company         String
  source          String?
  sourceUrl       String?
  status          ApplicationStatus @default(SAVED)
  appliedAt       DateTime?
  followUpAt      DateTime?
  recruiterName   String?
  recruiterEmail  String?
  recruiterPhone  String?
  notes           String?
  rejectionReason String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  job      Job?      @relation(fields: [jobId], references: [id])
  cv       CvVersion? @relation(fields: [cvVersionId], references: [id])
  timeline ApplicationTimeline[]

  @@index([userId])
  @@index([status])
  @@index([appliedAt])
  @@map("applications")
}

enum ApplicationStatus {
  SAVED
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  ACCEPTED
  REJECTED
  WITHDRAWN
}

model ApplicationTimeline {
  id            String   @id @default(uuid())
  applicationId String
  action        String
  description   String?
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("application_timeline")
}

model SavedJob {
  id        String   @id @default(uuid())
  userId    String
  jobId     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@map("saved_jobs")
}

// ============================================================
// CV (Prepared for Sprint 4)
// ============================================================

model CvVersion {
  id              String    @id @default(uuid())
  userId          String
  name            String
  templateId      String?
  content         Json?     // Structured CV content
  targetPosition  String?
  targetCompany   String?
  atsScore        Int?
  pdfUrl          String?
  isDefault       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]

  @@index([userId])
  @@map("cv_versions")
}

// ============================================================
// MOOD TRACKING (Prepared for Sprint 19)
// ============================================================

model MoodEntry {
  id        String    @id @default(uuid())
  userId    String
  mood      Int       // 1-5
  journal   String?
  date      DateTime  @default(now())
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@map("mood_entries")
}
